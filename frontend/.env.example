# frontend/.env.example

# --- Environment Variables for the AI Investment Research Agent Frontend ---
#
# INSTRUCTIONS:
# 1. Rename this file to ".env" in the /frontend directory.
# 2. This file allows you to override the default backend URL if needed.
#
# For local development, this file is optional as the default is set in apiService.js.
# For production, you will set this in your Vercel deployment settings.

# The full URL to your deployed backend API.
# Example: VITE_API_URL=https://your-backend-deployment.vercel.app/api